# Root .env.docker.example — copy to .env.docker: `cp .env.docker.example .env.docker`
#
# THE env file for running the stack via docker compose. It serves two roles:
#
#   1. Compose interpolation — values for ${AGENCY_PORT}, ${DB_*} in compose.yaml.
#      Compose only reads this for interpolation when you pass
#      `--env-file .env.docker` (it is not the auto-loaded ".env" name), so run:
#          docker compose --env-file .env.docker up --build
#
#   2. Container runtime overlay — listed as a second `env_file:` on the server
#      service (after backend/.env, so these win). It overrides the URLs the
#      backend *dials* with host.docker.internal, since inside a container
#      "localhost" is the container itself, not your host.
#
# backend/.env is kept only for bare-metal `go run`. This file is the docker one.

# ---------------------------------------------------------------------------
# Compose interpolation (host port mappings + db container init)
# ---------------------------------------------------------------------------

# Postgres: initializes the db container AND injected into server + migrate
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nsw_agency_db

# Agency backend: host port == container listen port (kept equal, one source).
# The server now serves the officer portal on this same port — there is no
# separate frontend container. The browser's VITE_* runtime config comes from
# frontend/.env (layered onto the server in compose.yaml), and compose overrides
# VITE_API_BASE_URL to point at this port, so nothing VITE_* belongs here.
AGENCY_PORT=8081

# ---------------------------------------------------------------------------
# Container runtime overlay — URLs the backend DIALS, via host.docker.internal.
# Resolves automatically on Docker Desktop; compose adds extra_hosts for Linux.
#
# IMPORTANT: only DIALED URLs belong here. Claim-matched values stay localhost
# in backend/.env, or auth breaks:
#   - AUTH_ISSUER   -> compared to the token's `iss` claim  -> KEEP localhost
#   - AUTH_AUDIENCE -> compared to the token's `aud` claim  -> KEEP localhost
# ---------------------------------------------------------------------------

# JWKS endpoint the server fetches signing keys from (dialed)
AUTH_JWKS_URL=https://host.docker.internal:8090/oauth2/jwks

# NSW API the server calls (dialed)
NSW_API_BASE_URL=http://host.docker.internal:8080/api/v1

# NSW OAuth2 token endpoint the server calls (dialed)
NSW_TOKEN_URL=https://host.docker.internal:8090/oauth2/token
