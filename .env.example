# Root .env.example — copy to .env: `cp .env.example .env`
#
# THE single, self-contained env file for running the stack via docker compose.
# It is the ONLY env_file the containers load — backend/.env and frontend/.env
# are NOT read by compose (they exist only for bare-metal `go run` / `pnpm dev`).
#
# It serves two roles at once:
#
#   1. Compose interpolation — values for ${AGENCY_PORT}, ${DB_*} in compose.yaml.
#      `.env` is the name Compose auto-loads, so no flag is needed — just run:
#          docker compose up --build
#
#   2. Container runtime config — the full environment for the server (API +
#      officer-portal SPA) and the migrate one-shot. The server emits the VITE_*
#      values to the browser at /runtime-env.js.
#
# localhost vs host.docker.internal — read before editing URLs:
#   - DIALED URLs (the server opens a connection to them) must use
#     host.docker.internal, because inside a container "localhost" is the
#     container itself, not your host: AUTH_JWKS_URL, NSW_API_BASE_URL,
#     NSW_TOKEN_URL.
#   - CLAIM-MATCHED values are compared to JWT claims, never dialed, so they must
#     stay exactly what the IdP issued (localhost): AUTH_ISSUER, AUTH_AUDIENCE.
#   - BROWSER-FACING VITE_* values are used by the SPA running in your browser on
#     the host, so they also stay localhost: VITE_IDP_BASE_URL, VITE_APP_URL,
#     VITE_API_BASE_URL.
#
# The values below are DEV DEFAULTS for the NPQS agency against a local NSW-core
# IdP (https://localhost:8090). Swap the per-agency identifiers (client ids, OU
# handle) for the agency you are running. Secrets are dev placeholders — do not
# use them in production.

# ===========================================================================
# Compose interpolation (host port mapping + postgres container init)
# ===========================================================================

# Postgres: initialises the db container AND injected into server + migrate.
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nsw_agency_db

# Agency server: host port == container listen port (kept equal, one source).
# The server serves BOTH the API and the officer portal on this one port —
# there is no separate frontend container.
AGENCY_PORT=8081

# ===========================================================================
# Backend — database & general
# ===========================================================================
# DB_DRIVER/HOST/PORT and DB_USER/PASSWORD/NAME for the container connection are
# set by compose.yaml's environment: blocks (they point the server/migrate at
# the `db` service). Listed here only for completeness / non-compose runs.
DB_DRIVER=postgres
DB_SSLMODE=disable

# Optional config dirs (empty = use built-in defaults bundled in the image).

# Comma-separated allowed CORS origins (* allows all — fine for local dev).
ALLOWED_ORIGINS=*

# Directory the built SPA is served from, relative to the working dir (/app).
WEB_DIR=web

# ===========================================================================
# Officer-portal SPA — browser-facing runtime config (served at /runtime-env.js)
# These run in your browser on the host, so they use localhost, NOT
# host.docker.internal.
# ===========================================================================
# Only default.branding.json ships in the image; per-agency branding files are
# gitignored, so keep this `default` unless you bake in another branding file.
VITE_BRANDING_NAME=default
# API base URL the browser calls. compose.yaml overrides this to use AGENCY_PORT.
VITE_API_BASE_URL=http://localhost:8081
# Identity Provider the browser is redirected to for login.
VITE_IDP_BASE_URL=https://localhost:8090
VITE_IDP_CLIENT_ID=OGA_PORTAL_APP_NPQS
# Portal app URL (used in OIDC redirects) — the host-reachable server address.
VITE_APP_URL=http://localhost:8081
VITE_IDP_SCOPES=openid,profile,email,ou,role,agency:application:read,agency:application:review,agency:application:feedback,agency:consignment:read,agency:storage:read,agency:storage:write
# OU handle the portal restricts access to (users with a different ouHandle
# claim see the unauthorized screen).
VITE_IDP_EXPECTED_OU_HANDLE=npqs

# ===========================================================================
# Inbound Auth — tokens the Agency backend accepts from the SPA / m2m clients
# ===========================================================================
# JWKS endpoint the server FETCHES signing keys from (dialed -> host.docker.internal).
AUTH_JWKS_URL=https://host.docker.internal:8090/oauth2/jwks
# Issuer expected in the JWT `iss` claim (matched, not dialed -> localhost).
AUTH_ISSUER=https://localhost:8090
# Audience expected in the JWT `aud` claim (matched, not dialed -> localhost).
AUTH_AUDIENCE=AGENCY_API
# Allowed client_id values: the SPA portal client + the NSW->Agency m2m client.
AUTH_CLIENT_IDS=OGA_PORTAL_APP_NPQS,NSW_TO_NPQS
# This agency's OU handle — must match the ouHandle claim in user JWTs.
AUTH_EXPECTED_OU=npqs
# DEV-ONLY: skip TLS verification for the JWKS endpoint. Keep false in production.
AUTH_JWKS_INSECURE_SKIP_VERIFY=true

# ===========================================================================
# Outbound Auth — credentials the Agency backend uses to call the NSW API
# ===========================================================================
# NSW API base URL the server calls (dialed -> host.docker.internal).
NSW_API_BASE_URL=http://host.docker.internal:8080/api/v1
# OAuth2 client credentials for the Agency -> NSW m2m call.
NSW_CLIENT_ID=NPQS_TO_NSW
NSW_CLIENT_SECRET=changeme
# NSW OAuth2 token endpoint the server calls (dialed -> host.docker.internal).
NSW_TOKEN_URL=https://host.docker.internal:8090/oauth2/token
NSW_SCOPES=nsw:task:write,nsw:consignment:read,nsw:storage:read,nsw:storage:write
# DEV-ONLY: skip TLS verification for the NSW token endpoint. Keep false in production.
NSW_TOKEN_INSECURE_SKIP_VERIFY=true
