# Port the Agency server listens on
PORT=8081

# Database driver: sqlite | postgres
DB_DRIVER=sqlite

# SQLite settings (used if DB_DRIVER=sqlite)
DB_PATH=./agency_applications.db

# PostgreSQL settings (used if DB_DRIVER=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=nsw_agency_db
DB_SSLMODE=disable

# Path to SQL migration files directory
MIGRATION_DIR=./migrations

# Directory containing task configurations
TASK_CONFIGS_DIR=

# Directory containing form templates
FORM_TEMPLATES_DIR=

# Comma-separated list of allowed CORS origins (use * to allow all)
ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Officer-portal SPA (optional for bare-metal dev)
# ---------------------------------------------------------------------------
# The server serves the built portal and /runtime-env.js when WEB_DIR exists.
# For normal `go run` dev the frontend runs via its own Vite dev server and this
# dir is absent, so the server runs API-only and you can leave this section blank.
# It applies only to a local bundled-serving test build:
#   (cd frontend && pnpm build --outDir ../backend/web)
# in which case the VITE_* values below are served to the browser and the four
# marked REQUIRED are validated at startup.

# Directory the built SPA is served from, relative to the working dir.
WEB_DIR=web

# Branding config name -> /configs/${VITE_BRANDING_NAME}.branding.json
VITE_BRANDING_NAME=default
# Backend API base URL the browser calls (REQUIRED when serving the portal)
VITE_API_BASE_URL=http://localhost:8081
# Identity Provider (REQUIRED when serving the portal)
VITE_IDP_BASE_URL=https://localhost:8090
VITE_IDP_CLIENT_ID=<SPA_AGENCY_PORTAL>
# Portal app URL (used in OIDC redirects)
VITE_APP_URL=http://localhost:8081
# OAuth scopes requested at login (comma-separated)
VITE_IDP_SCOPES=openid,profile,email,ou
# Agency OU handle the portal restricts access to (REQUIRED when serving the portal)
VITE_IDP_EXPECTED_OU_HANDLE=

# ---------------------------------------------------------------------------
# Inbound Auth — tokens the Agency backend accepts from the SPA / m2m clients
# ---------------------------------------------------------------------------

# JWKS endpoint of the IdP (used to verify incoming JWT signatures)
AUTH_JWKS_URL=https://localhost:8090/oauth2/jwks

# Expected issuer claim in incoming JWTs
AUTH_ISSUER=https://localhost:8090

# Expected audience claim in incoming JWTs.
# Each Agency has its own resource server registered in the IdP.
AUTH_AUDIENCE=AGENCY_API

# Comma-separated list of allowed client_id values in incoming JWTs.
# Typically two clients: the SPA portal and the NSW->Agency m2m client.
# With start-dev.sh these are derived per agency, e.g. NPQS:
#   OGA_PORTAL_APP_NPQS,NSW_TO_NPQS
AUTH_CLIENT_IDS=<SPA_AGENCY_PORTAL>,NSW_TO_<AGENCY>

# The agency's OU handle — must match the ouHandle claim in user JWTs.
# Used to enforce that only users belonging to this agency can log in.
AUTH_EXPECTED_OU=

# DEV-ONLY: set to true to skip TLS verification for the JWKS endpoint.
# Keep false in production.
AUTH_JWKS_INSECURE_SKIP_VERIFY=true

# ---------------------------------------------------------------------------
# Outbound Auth — credentials used by the Agency backend to call the NSW API
# ---------------------------------------------------------------------------

# Base URL of the NSW API
NSW_API_BASE_URL=http://localhost:8080/api/v1

# OAuth2 client credentials for the Agency -> NSW m2m call.
# Must correspond to a client registered in the IdP with access to the NSW API.
NSW_CLIENT_ID=<M2M_AGENCY_TO_NSW>
NSW_CLIENT_SECRET=changeme
NSW_TOKEN_URL=https://localhost:8090/oauth2/token

# Comma-separated scopes requested when obtaining NSW API tokens.
# Must match the scopes granted to the M2M client's role in the IdP
# (AgencyM2M role -> NSW_API resource server).
NSW_SCOPES=nsw:task:write,nsw:consignment:read,nsw:storage:read,nsw:storage:write

# DEV-ONLY: set to true to skip TLS verification for the NSW token endpoint.
# Keep false in production.
NSW_TOKEN_INSECURE_SKIP_VERIFY=true
