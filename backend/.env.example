# Port the OGA server listens on
OGA_PORT=8081

# Database driver: sqlite | postgres
OGA_DB_DRIVER=sqlite

# SQLite settings (used if OGA_DB_DRIVER=sqlite)
OGA_DB_PATH=./oga_applications.db

# PostgreSQL settings (used if OGA_DB_DRIVER=postgres)
OGA_DB_HOST=localhost
OGA_DB_PORT=5432
OGA_DB_USER=postgres
OGA_DB_PASSWORD=changeme
OGA_DB_NAME=oga_db
OGA_DB_SSLMODE=disable

# Directory containing form definition files
OGA_FORMS_PATH=./data/forms

# Fallback form ID used when no form is specified in the request
OGA_DEFAULT_FORM_ID=default

# Comma-separated list of allowed CORS origins (use * to allow all)
OGA_ALLOWED_ORIGINS=*